{
  "title": "LENDING API",
  "uid": "lending-api",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": [
    "lending",
    "api",
    "springboot"
  ],
  "templating": {
    "list": [
      {
        "name": "application",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(jvm_memory_used_bytes, application)",
        "current": {
          "selected": true,
          "text": "lending-api",
          "value": "lending-api"
        }
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(jvm_memory_used_bytes{application=\"$application\"}, instance)",
        "current": {
          "selected": true,
          "text": "lending-api:8088",
          "value": "lending-api:8088"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API Up",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "up{job=\"lending-api\",instance=\"$instance\"}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Requests/sec",
      "gridPos": {
        "h": 8,
        "w": 10,
        "x": 4,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\",instance=\"$instance\"}[1m]))"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Average Response Time",
      "gridPos": {
        "h": 8,
        "w": 10,
        "x": 14,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_sum{application=\"$application\",instance=\"$instance\"}[1m]) / rate(http_server_requests_seconds_count{application=\"$application\",instance=\"$instance\"}[1m])"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "4xx Responses/sec",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\",instance=\"$instance\",status=~\"4..\"}[1m]))"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "5xx Responses/sec",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\",instance=\"$instance\",status=~\"5..\"}[1m]))"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Exceptions/sec",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\",instance=\"$instance\",exception!=\"None\"}[1m]))"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Top Endpoints",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "format": "table",
          "instant": true,
          "expr": "topk(15,sum(rate(http_server_requests_seconds_count{application=\"$application\",instance=\"$instance\"}[5m])) by (uri,method))"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Request Duration (95th Percentile)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95,sum(rate(http_server_requests_seconds_bucket{application=\"$application\",instance=\"$instance\"}[5m])) by (le))"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Request Duration (99th Percentile)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 26
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99,sum(rate(http_server_requests_seconds_bucket{application=\"$application\",instance=\"$instance\"}[5m])) by (le))"
        }
      ]
    }
  ]
}
{
  "title": "LENDING PostgreSQL",
  "uid": "lending-postgres",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": [
    "postgres",
    "database"
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Database Up",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "pg_up"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Connections",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Database Size",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "expr": "pg_database_size_bytes"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cache Hit Ratio",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      },
      "targets": [
        {
          "expr": "100 * sum(pg_stat_database_blks_hit)/(sum(pg_stat_database_blks_hit)+sum(pg_stat_database_blks_read))"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Transactions/sec",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit[5m])"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback[5m])"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Rows Returned/sec",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_returned[5m])"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Rows Inserted/sec",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_inserted[5m])"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Rows Updated/sec",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 13
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_updated[5m])"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Rows Deleted/sec",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 13
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_deleted[5m])"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Deadlocks",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 21
      },
      "targets": [
        {
          "expr": "increase(pg_stat_database_deadlocks[1h])"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Temporary Files",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_temp_files[5m])"
        }
      ]
    }
  ]
}